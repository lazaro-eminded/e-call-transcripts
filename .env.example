# GHL Private Integration Token — required scopes:
#   conversations.readonly  (fallback search when URL is not in webhook payload)
#   contacts.write          (post call notes)
GHL_API_KEY=pit-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GHL_LOCATION_ID=xxxxxxxxxxxxxxxxxxxxxxxx
GHL_USER_ID=                          # opcional — ID del usuario GHL que firma las notas
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MIN_CALL_DURATION_SECONDS=60
RECORDING_DELAY_SECONDS=60
