GHL_API_KEY=pit-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GHL_LOCATION_ID=xxxxxxxxxxxxxxxxxxxxxxxx
GHL_USER_ID=                          # opcional — ID del usuario GHL que firma las notas
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MIN_CALL_DURATION_SECONDS=60
RECORDING_DELAY_SECONDS=60

# Para múltiples subcuentas en Railway/cloud, usar LOCATIONS_JSON (tiene prioridad sobre lo de arriba):
# LOCATIONS_JSON={"LOCATION_ID_1":{"api_key":"pit-xxx","user_id":""},"LOCATION_ID_2":{"api_key":"pit-yyy","user_id":""}}
#
# En desarrollo local también puedes usar locations.json (ver locations.json.example).
